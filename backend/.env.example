# ============================================================
# TurnoGO — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env or real secrets to the repository.
# ============================================================

# --- App ---
APP_URL=http://localhost:8000
ENVIRONMENT=development

# Environment
ENVIRONMENT=development

# --- Database ---
DATABASE_URL=sqlite:///./freelance.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Blockchain (Polygon) ---
SYSTEM_WALLET_ADDRESS=
SYSTEM_WALLET_PRIVATE_KEY=
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
USDT_CONTRACT_ADDRESS=

# --- Cloudinary (profile images) ---
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Didit (KYC verification) ---
# Sign up at https://business.didit.me
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
DIDIT_WORKFLOW_ID=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=

# --- Email (SendGrid) ---
# Sign up at https://sendgrid.com (free: 100/day)
SENDGRID_API_KEY=

# --- Email (Resend) ---
# Sign up at https://resend.com
RESEND_API_KEY=

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Sentry (error monitoring) ---
SENTRY_DSN=

# --- Webhooks ---
WEBHOOK_SECRET=
WEBHOOK_ALLOWED_IPS=

# --- Frontend ---
FRONTEND_URL=
